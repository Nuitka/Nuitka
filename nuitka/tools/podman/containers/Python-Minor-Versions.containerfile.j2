FROM debian:buster

COPY bin/compile-python-for-nuitka-linux.sh /usr/local/bin/compile-python-for-nuitka-linux.sh
RUN chmod +x /usr/local/bin/compile-python-for-nuitka-linux.sh

# Install dependencies
# spell-checker: ignore libncurses libgdbm libnss libreadline
RUN apt-get update && apt-get install -y curl wget build-essential zlib1g-dev libncurses5-dev libgdbm-dev libnss3-dev
libssl-dev libreadline-dev libffi-dev gdb ccache

{% set versions = ["3.7.3", "3.7.4", "3.12.6", "3.12.7"] %}
{% for version in versions %}
# Install Python {{ version }}
RUN /usr/local/bin/compile-python-for-nuitka-linux.sh --version {{ version }} \
&& rm -rf Python-{{ version }} Python-{{ version }}.tar.xz
{% endfor %}

{#-  Part of "Nuitka", an optimizing Python compiler that is compatible and           -#}
